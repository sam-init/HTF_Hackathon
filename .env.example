# GitHub App credentials
GITHUB_APP_ID=your_app_id
GITHUB_PRIVATE_KEY_PATH=./config/private-key.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# NVIDIA NIM API keys (free tier)
NVIDIA_API_KEY=your_nvidia_nim_api_key

# Model names (NVIDIA NIM free models)
NIM_STRUCTURE_MODEL=nvidia/nemotron-3-super-120b-a12b
NIM_DOCS_MODEL=qwen/qwen3.5-397b-a17b
NIM_REVIEW_MODEL=qwen/qwen3.5-122b-a10b

# Database
DATABASE_URL=sqlite:///./deviq.db

# App config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
